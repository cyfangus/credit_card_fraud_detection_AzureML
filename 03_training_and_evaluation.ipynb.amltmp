            "text/html": "<div>\n<style scoped>\n    .dataframe tbody tr th:only-of-type {\n        vertical-align: middle;\n    }\n\n    .dataframe tbody tr th {\n        vertical-align: top;\n    }\n\n    .dataframe thead th {\n        text-align: right;\n    }\n</style>\n<table border=\"1\" class=\"dataframe\">\n  <thead>\n    <tr style=\"text-align: right;\">\n      <th></th>\n      <th>Algorithm</th>\n      <th>Data Strategy</th>\n      <th>Duration (s)</th>\n      <th>AUPRC</th>\n      <th>Recall</th>\n      <th>Precision</th>\n      <th>F1-Score</th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <th>0</th>\n      <td>Random_Forest</td>\n      <td>Imbalanced</td>\n      <td>90.956</td>\n      <td>0.864065</td>\n      <td>0.816327</td>\n      <td>0.952381</td>\n      <td>0.879121</td>\n    </tr>\n    <tr>\n      <th>1</th>\n      <td>XGBoost</td>\n      <td>SMOTE</td>\n      <td>8.004</td>\n      <td>0.847698</td>\n      <td>0.877551</td>\n      <td>0.375546</td>\n      <td>0.525994</td>\n    </tr>\n    <tr>\n      <th>2</th>\n      <td>XGBoost</td>\n      <td>Imbalanced</td>\n      <td>6.606</td>\n      <td>0.834129</td>\n      <td>0.765306</td>\n      <td>0.914634</td>\n      <td>0.833333</td>\n    </tr>\n    <tr>\n      <th>3</th>\n      <td>Random_Forest</td>\n      <td>SMOTE</td>\n      <td>168.485</td>\n      <td>0.806428</td>\n      <td>0.867347</td>\n      <td>0.397196</td>\n      <td>0.544872</td>\n    </tr>\n    <tr>\n      <th>4</th>\n      <td>Logistic_Regression</td>\n      <td>Imbalanced</td>\n      <td>4.025</td>\n      <td>0.735294</td>\n      <td>0.653061</td>\n      <td>0.790123</td>\n      <td>0.715084</td>\n    </tr>\n    <tr>\n      <th>5</th>\n      <td>Logistic_Regression</td>\n      <td>SMOTE</td>\n      <td>17.445</td>\n      <td>0.727711</td>\n      <td>0.918367</td>\n      <td>0.054979</td>\n      <td>0.103746</td>\n    </tr>\n  </tbody>\n</table>\n</div>"
          },
          "metadata": {}
        }
      ],
      "execution_count": 16,
      "metadata": {
        "gather": {
          "logged": 1772197080924
        }
      }
    },
    {
      "cell_type": "code",
      "source": [
        "mlflow.set_experiment(\"XGBoost_hyperparameter_tuning\")\n",
        "mlflow.sklearn.autolog(max_tuning_runs=15, log_models=True)\n",
        "\n",
        "# 1. Define the XGBoost Pipeline\n",
        "xgb_pipeline = ImbPipeline([\n",
        "    ('smote', SMOTE(random_state=42)),\n",
        "    ('xgb', XGBClassifier(random_state=42, use_label_encoder=False, eval_metric='logloss'))\n",
        "])\n",
        "\n",
        "# 2. Regularization-focused Search Space\n",
        "# 'reg_alpha' and 'reg_lambda' are the \"magic\" parameters that stop overfitting\n",
        "param_dist_xgb = {\n",
        "    'xgb__n_estimators': [100, 200],\n",
        "    'xgb__learning_rate': [0.01, 0.1],\n",
        "    'xgb__max_depth': [3, 6],\n",
        "    'xgb__reg_alpha': [0, 0.1, 1], \n",
        "    'xgb__reg_lambda': [1, 5]\n",
        "}\n",
        "\n",
        "random_search_xgb = RandomizedSearchCV(\n",
        "    estimator=xgb_pipeline,\n",
        "    param_distributions=param_dist_xgb,\n",
        "    n_iter=10,\n",
        "    cv=3,\n",
        "    scoring='average_precision',\n",
        "    n_jobs=-1,\n",
        "    verbose=3\n",
        ")\n",
        "\n",
        "print(\"Tuning XGBoost...\")\n",
        "random_search_xgb.fit(X_train_imb, y_train_imb)\n",
        "\n",
        "print(f\"Best AUPRC Found: {random_search_xgb.best_score_:.4f}\")\n",
        "print(f\"Best Params: {random_search_xgb.best_params_}\")"
      ],
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": "Tuning XGBoost...\nFitting 3 folds for each of 10 candidates, totalling 30 fits\nBest AUPRC Found: 0.8432\nBest Params: {'xgb__reg_lambda': 5, 'xgb__reg_alpha': 0, 'xgb__n_estimators': 200, 'xgb__max_depth': 6, 'xgb__learning_rate': 0.1}\n"
        },
        {
