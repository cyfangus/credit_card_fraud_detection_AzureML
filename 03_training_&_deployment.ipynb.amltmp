            "text/html": "<div>\n<style scoped>\n    .dataframe tbody tr th:only-of-type {\n        vertical-align: middle;\n    }\n\n    .dataframe tbody tr th {\n        vertical-align: top;\n    }\n\n    .dataframe thead th {\n        text-align: right;\n    }\n</style>\n<table border=\"1\" class=\"dataframe\">\n  <thead>\n    <tr style=\"text-align: right;\">\n      <th></th>\n      <th>Algorithm</th>\n      <th>AUPRC</th>\n      <th>Recall</th>\n      <th>Precision</th>\n      <th>F1-Score</th>\n      <th>Duration (s)</th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <th>0</th>\n      <td>XGBoost</td>\n      <td>0.861749</td>\n      <td>0.846939</td>\n      <td>0.775701</td>\n      <td>0.809756</td>\n      <td>5.050</td>\n    </tr>\n    <tr>\n      <th>1</th>\n      <td>Random_Forest</td>\n      <td>0.828539</td>\n      <td>0.826531</td>\n      <td>0.778846</td>\n      <td>0.801980</td>\n      <td>73.002</td>\n    </tr>\n    <tr>\n      <th>2</th>\n      <td>Logistic_Regression</td>\n      <td>0.723185</td>\n      <td>0.918367</td>\n      <td>0.055556</td>\n      <td>0.104773</td>\n      <td>7.669</td>\n    </tr>\n  </tbody>\n</table>\n</div>"
          },
          "metadata": {}
        }
      ],
      "execution_count": 8,
      "metadata": {
        "gather": {
